<!--
  Sanitized example of a successful Cordys SSO SAML 1.1 response.
  Captured from a live AppWorks 25.1 (Process Automation CE) instance.
  Username, hostnames, IDs, signature and artifact values redacted.

  The shape is what matters:
    SOAP:Body / samlp:Response / samlp:Status / samlp:StatusCode @ Value
      -> "samlp:Success" on success
    SOAP:Body / samlp:Response / samlp:AssertionArtifact
      -> opaque artifact, ~176 chars, base64-ish; pass into AuthenticationToken.wcp
         as the SAMLart request header to mint a session cookie.

  Failure path returns a SOAP:Fault with
    cordys:FaultDetails / cordys:LocalizableMessage / cordys:MessageCode
      = "Cordys.ESBServer.Messages.invalidCredentials"
-->
<SOAP:Envelope xmlns:SOAP="http://schemas.xmlsoap.org/soap/envelope/">
  <SOAP:Header xmlns:SOAP="http://schemas.xmlsoap.org/soap/envelope/">
    <header xmlns:SOAP="http://schemas.xmlsoap.org/soap/envelope/"
            xmlns="http://schemas.cordys.com/General/1.0/">
      <msg-id>REDACTED-MSG-ID</msg-id>
      <messageoptions noreply="true"/>
    </header>
  </SOAP:Header>
  <SOAP:Body>
    <samlp:Response xmlns:samlp="urn:oasis:names:tc:SAML:1.0:protocol"
                    IssueInstant="2026-05-14T17:53:34.599Z"
                    MajorVersion="1" MinorVersion="1"
                    ResponseID="AREDACTED-RESPONSE-ID"
                    InResponseTo="aREDACTED-REQUEST-ID">
      <Signature xmlns="http://www.w3.org/2000/09/xmldsig#">
        <SignedInfo>
          <CanonicalizationMethod Algorithm="http://www.w3.org/2001/10/xml-exc-c14n#"/>
          <SignatureMethod Algorithm="http://www.w3.org/2001/04/xmldsig-more#rsa-sha256"/>
          <Reference URI="#AREDACTED-ASSERTION-ID">
            <Transforms>
              <Transform Algorithm="http://www.w3.org/2000/09/xmldsig#enveloped-signature"/>
              <Transform Algorithm="http://www.w3.org/2001/10/xml-exc-c14n#"/>
            </Transforms>
            <DigestMethod Algorithm="http://www.w3.org/2001/04/xmlenc#sha256"/>
            <DigestValue>REDACTED-DIGEST</DigestValue>
          </Reference>
        </SignedInfo>
        <SignatureValue>REDACTED-SIGNATURE</SignatureValue>
      </Signature>
      <samlp:Status>
        <samlp:StatusCode Value="samlp:Success"/>
      </samlp:Status>
      <saml:Assertion xmlns:saml="urn:oasis:names:tc:SAML:1.0:assertion"
                      AssertionID="AREDACTED-ASSERTION-ID"
                      IssueInstant="2026-05-14T17:53:34.599Z"
                      Issuer="https://www.cordys.com/SSO"
                      MajorVersion="1" MinorVersion="1">
        <saml:Conditions NotBefore="2026-05-14T17:48:34.599Z"
                         NotOnOrAfter="2026-05-15T01:53:34.599Z"/>
        <saml:AuthenticationStatement
            AuthenticationInstant="2026-05-14T17:53:34.599Z"
            AuthenticationMethod="urn:oasis:names:tc:SAML:1.0:am:password">
          <saml:Subject>
            <saml:NameIdentifier>awpadmin@ExampleAuth</saml:NameIdentifier>
          </saml:Subject>
        </saml:AuthenticationStatement>
      </saml:Assertion>
      <samlp:AssertionArtifact>REDACTED-ARTIFACT-176CHARS</samlp:AssertionArtifact>
    </samlp:Response>
  </SOAP:Body>
</SOAP:Envelope>
